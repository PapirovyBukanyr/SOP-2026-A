	language = {en},
	publisher = {Prentice Hall, Incorporated},
	author = {Munkres, James R.},
	year = {2000},
	note = {Google-Books-ID: XjoZAQAAIAAJ},
	keywords = {Mathematics / Algebra / General, Mathematics / Topology},
}

